# My Projects
ARTKAI_DIR="$HOME/artkai"
alias vera="cd $ARTKAI_DIR/01-vera/backend"
alias tags="cd $ARTKAI_DIR/01-vera/tags"
alias testing="cd $ARTKAI_DIR/02-quipu/testing"
alias cms="cd $ARTKAI_DIR/02-quipu/cms"
alias quant="cd $ARTKAI_DIR/03-quantlake/backend"
alias iac="cd $ARTKAI_DIR/03-quantlake/iac"
alias rtlb="cd $ARTKAI_DIR/05-eurodollar/rtl-backend"

# Navigation

# System
alias c="clear"
alias h="history"
alias hs="history | rg"
alias ls="ls --color"
alias l="ls -lh"
alias la="ls -lAht"
alias lt="ls -lht"
alias lat="ls -lAht"
alias dud='du -d 1 -h'
alias ff='find . -type f -name'
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# ZSH
alias zconf="nvim ~/.zshrc"
alias zdir="cd ~/.config/zsh"
alias zprompt="nvim ~/.config/zsh/tdk-prompt.zsh"
alias zalias="nvim ~/.config/zsh/tdk-aliases.zsh"
alias zhome="nvim ~/.config/zsh/tdk-home.zsh"
alias zso="source ~/.zshrc"

# Neovim Editor
alias vim="nvim"
alias v="nvim ."

# Sublime *
alias text="subl"
alias merge="smerge"

# Git
alias gst="git status"
alias gd="git diff"
